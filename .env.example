# Web (my-nonprofit-console) — server-side env vars only (no NEXT_PUBLIC_* secrets)

# Listen port for Next.js (default dev: 3081)
PORT=3081

# Required in production — Express base URL for Next rewrites (no trailing slash)
# Dev default: http://127.0.0.1:3080 when unset and NODE_ENV !== production
EXPRESS_API_URL=http://127.0.0.1:3080

# Optional — must match Express FORMATION_API_SECRET when API is protected (server-side only)
# FORMATION_API_SECRET=
